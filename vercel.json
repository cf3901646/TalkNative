{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.py"
        },
        {
            "source": "/((?!api|assets|logo\\.png|sw\\.js|manifest\\.json).*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/(index.html|sw.js|manifest.json)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, must-revalidate"
                }
            ]
        }
    ]
}